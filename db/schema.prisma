// Prisma 스키마 — 공부사주
// DB: Supabase Postgres + PostGIS
//
// 사용법:
//   1. DATABASE_URL을 .env에 설정
//   2. npx prisma migrate dev  (또는 001_init.sql 직접 실행)
//   3. npx prisma generate

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  // 연결 URL은 Prisma 7부터 prisma.config.ts(datasource.url)에서 주입한다.
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────
// 주문·결제
// ──────────────────────────────────────────────────────────────
model Order {
  id           String   @id @default(cuid())
  tier         String   // "basic" | "premium"
  status       String   @default("paid")
  // paid → generating → review → published / rejected / failed
  // paid / rejected / failed → refunded (환불)
  userId       String?  // Supabase auth.users UUID (null = 비회원)
  subjectId    String   // subjects 외래키 (PII 분리)
  reportId     String?
  // 토스 결제 승인 키 — 환불(결제취소 API) 시 필요. 모의 결제(TOSS_SECRET_KEY 미설정)면 null.
  paymentKey   String?
  refundedAt   DateTime?
  refundReason String?
  // 알림 발송용 연락처 (보호자) — 별도 동의
  contactEmail String?
  contactPhone String?
  // 발행 시 결과 링크 발송 실패 기록 — 운영자가 어드민에서 보고 재발송할 수 있게.
  // 성공하면 null로 비운다.
  notifyError    String?
  notifyFailedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@map("orders")
}

// ──────────────────────────────────────────────────────────────
// 자녀 PII (암호화·분리 저장 필수, 법정대리인 동의)
// ──────────────────────────────────────────────────────────────
model Subject {
  id               String   @id @default(cuid())
  // 아래 필드는 애플리케이션 레이어(lib/crypto/pii)에서 암호화 후 저장
  encBirthYear     String
  encBirthMonth    String
  encBirthDay      String
  encBirthHour     String?  // null = 시간 모름
  encBirthMinute   String?
  encGender        String
  encAddress       String?  // Premium용
  encCurrentSchool String?  // Premium용
  encName          String?  // 아이 이름(한글) — 표지·요약 호명용. LLM 미전송
  encNameHanja     String?  // 아이 이름 한자(선택) — 자원오행 분석용. LLM 미전송
  consentAt        DateTime
  retainUntil      DateTime // 보관 기간 (동의 시 명시)
  createdAt        DateTime @default(now())

  @@map("subjects")
}

// ──────────────────────────────────────────────────────────────
// 사주 계산 캐시 (생년월일시 해시 키, PII 미포함)
// ──────────────────────────────────────────────────────────────
model SajuResult {
  id          String   @id @default(cuid())
  inputHash   String   @unique // SHA256(birthYear|month|day|hour|gender)
  resultJson  String   // SajuResult JSON (암호화 권장)
  createdAt   DateTime @default(now())

  @@map("saju_results")
}

// 주의: 학교 사실 레이어(schools / school_zones / admission_stats)는
// PostGIS geometry 컬럼을 쓰므로 Prisma가 아니라 raw SQL로 관리한다.
// → db/postgis/schools_postgis.sql (data-pipeline 적재용, 별도 실행)
// Prisma는 주문 흐름(orders / subjects / saju_results / reports)만 관리한다.

// ──────────────────────────────────────────────────────────────
// 리포트 (생성물·토큰·PDF·검수 상태)
// ──────────────────────────────────────────────────────────────
model Report {
  id           String   @id @default(cuid())
  orderId      String   @unique
  token        String   @unique // 결과 페이지 접근 토큰 (앱에서 randomBytes 발급)
  tier         String   // "basic" | "premium"
  markdown     String   // 최종 마크다운 (검수·재생성 원본)
  html         String   // 렌더된 디자인 HTML (결과페이지 표시 캐시)
  reviewStatus String   @default("pending") // pending|approved|rejected
  reviewNote   String?  // 검수자 메모 (반려 사유 등)
  pdfUrl       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([reviewStatus])
  @@map("reports")
}

// ──────────────────────────────────────────────────────────────
// 아이 프로필 (회원용 — 재신청 편의)
// ──────────────────────────────────────────────────────────────
model ChildProfile {
  id             String   @id @default(cuid())
  userId         String   // Supabase auth.users UUID
  nickname       String   // 예: "첫째", "민준이" 등 (암호화 불필요 - 사용자 직접 입력 라벨)
  encBirthYear   String   // PII 암호화
  encBirthMonth  String
  encBirthDay    String
  encBirthHour   String?  // null = 시간 모름
  encBirthMinute String?
  encGender      String
  encAddress     String?  // Premium용
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("child_profiles")
}
